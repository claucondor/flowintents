# FlowIntents — deployment secrets template
# Copy to .env and fill in your values

DEPLOYER_ADDRESS=0x<your-mainnet-flow-address>
DEPLOYER_PRIVATE_KEY=<your-ecdsa-secp256k1-private-key>

# Only needed when running a mainnet fork locally (flow emulator --fork)
FORK_SERVICE_KEY=<fork-service-account-key>

FLOW_EVM_RPC=https://mainnet.evm.nodes.onflow.org
NETWORK=mainnet
